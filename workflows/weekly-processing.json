    {
      "id": "tj-wp-020",
      "name": "Update Amphitheater",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [4280, 300],
      "parameters": {
        "source": "database",
        "workflowId": "rUuhiK2xClpGJJad",
        "workflowInputs": {
          "mappingMode": "autoMapInputData",
          "value": {},
