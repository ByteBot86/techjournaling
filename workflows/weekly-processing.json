    {
      "id": "tj-wp-026",
      "name": "Get Weekly Tasks",
      "type": "n8n-nodes-base.googleTasks",
      "typeVersion": 1,
      "position": [920, 520],
      "parameters": {
        "resource": "task",
        "operation": "getAll",
        "task": "={{ '@default' }}",
        "returnAll": true,
        "additionalFields": {
          "showCompleted": true,
          "showHidden": true
        }
      },
      "credentials": {
        "googleTasksOAuth2Api": { "id": "googleTasksTechDiary", "name": "Google Tasks Tech Diary" }
      }
    },
    {
      "id": "tj-wp-027",
      "name": "Collect Task Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 520],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const userId = $('Set User').first().json.user_id;\nconst sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\n\nconst now = new Date();\nconst weekStart = new Date(now);\nweekStart.setDate(now.getDate() - now.getDay() + 1);\nweekStart.setHours(0, 0, 0, 0);\n\nconst allTasks = $input.all().map(i => i.json);\nconst thisWeekTasks = allTasks.filter(t => {\n  return new Date(t.updated) >= sevenDaysAgo;\n});\n\nconst completed = thisWeekTasks\n  .filter(t => t.status === 'completed')\n  .map(t => t.title || '');\n\nconst incomplete = thisWeekTasks\n  .filter(t => t.status === 'needsAction')\n  .map(t => t.title || '');\n\nconst incompleteCount = incomplete.length;\nconst maxNewTasks = Math.max(0, 4 - incompleteCount);\n\nreturn [{ json: {\n  user_id: userId,\n  week_start: weekStart.toISOString().split('T')[0],\n  completed_tasks: completed,\n  incomplete_tasks: incomplete,\n  incomplete_count: incompleteCount,\n  max_new_tasks: maxNewTasks\n} }];"
      }
    },
    {
      "id": "tj-wp-028",
      "name": "Save Task Completions",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1160, 700],
      "parameters": {
        "resource": "row",
        "operation": "create",
        "tableId": "task_completions",
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "user_id", "fieldValue": "={{ $json.user_id }}" },
            { "fieldId": "week_start", "fieldValue": "={{ $json.week_start }}" },
            { "fieldId": "completed", "fieldValue": "={{ JSON.stringify($json.completed_tasks) }}" },
            { "fieldId": "incomplete", "fieldValue": "={{ JSON.stringify($json.incomplete_tasks) }}" }
          ]
        }
      },
      "credentials": {
        "supabaseApi": { "id": "394dwMdNdGqslv7H", "name": "Supabase account" }
      }
    },
    {
      "id": "tj-wp-005",
      "name": "Get Journal Entries",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1400, 300],
      "alwaysOutputData": true,
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "journal_entries",
        "returnAll": true,
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "user_id",
              "condition": "eq",
              "keyValue": "={{ $json.user_id }}"
            },
            {
              "keyName": "created_at",
              "condition": "gte",
              "keyValue": "={{ new Date(Date.now() - 7*24*60*60*1000).toISOString() }}"
            }
          ]
        }
      },
      "credentials": {
        "supabaseApi": { "id": "394dwMdNdGqslv7H", "name": "Supabase account" }
      }
    },
    {
      "id": "tj-wp-006",
      "name": "Collect Journal",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1640, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const userId = $('Set User').first().json.user_id;\nconst items = $input.all();\nconst journalText = items\n  .filter(item => item.json.content)\n  .map(item => item.json.content)\n  .join('\\n\\n---\\n\\n');\n\nconst now = new Date();\nconst weekStart = new Date(now);\nweekStart.setDate(now.getDate() - now.getDay() + 1);\nweekStart.setHours(0, 0, 0, 0);\n\nreturn [{\n  json: {\n    user_id: userId,\n    journal_text: journalText,\n    has_entries: journalText.length > 0,\n    week_start: weekStart.toISOString().split('T')[0]\n  }\n}];"
      }
    },
    {
      "id": "tj-wp-007",
      "name": "Has Entries?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1880, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            {
              "id": "check-has-entries",
              "leftValue": "={{ $json.has_entries }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "tj-wp-008",
      "name": "Get Amphitheater",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2120, 300],
      "alwaysOutputData": true,
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "amphitheater",
        "returnAll": true,
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "user_id",
              "condition": "eq",
              "keyValue": "={{ $('Collect Journal').first().json.user_id }}"
            }
          ]
        }
      },
      "credentials": {
        "supabaseApi": { "id": "394dwMdNdGqslv7H", "name": "Supabase account" }
      }
    },
    {
      "id": "tj-wp-009",
      "name": "Build Weekly Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2360, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const journalData = $('Collect Journal').first().json;\nconst ampItems = $input.all();\nconst activeAmp = ampItems.filter(item => !item.json.metadata?.superseded_at);\nconst ampContext = activeAmp\n  .map(item => {\n    const cat = (item.json.metadata?.category || 'info').toUpperCase();\n    return `[${cat}] ${item.json.content}`;\n  })\n  .join('\\n\\n') || '(brak profilu w amfiteatrze)';\n\nconst taskData = $('Collect Task Status').first().json;\nconst completedList = (taskData.completed_tasks || []).map(t => `✅ ${t}`).join('\\n') || '(brak danych)';\nconst incompleteList = (taskData.incomplete_tasks || []).map(t => `❌ ${t}`).join('\\n') || '(brak niewykonanych)';\n\nconst fullPrompt = `Na podstawie wpisów z dziennika z tygodnia ${journalData.week_start} wykonaj dwa zadania:\\n\\n1. KONDENSACJA TYGODNIA: Zsyntetyzuj kluczowe tematy, wzorce, decyzje i spostrzeżenia z wpisów. Uwzględnij realizację zadań. Bądź konkretny i rzeczowy (200-400 słów).\\n\\n2. PLAN NA PRZYSZŁY TYDZIEŃ: Na podstawie kondensacji i profilu użytkownika zaproponuj konkretny plan (3-5 priorytetów/działań na najbliższy tydzień).\\n\\nPROFIL UŻYTKOWNIKA (amfiteatr):\\n${ampContext}\\n\\nREALIZACJA ZADAŃ Z MINIONEGO TYGODNIA:\\n${completedList}\\n${incompleteList}\\n\\nWPISY Z TYGODNIA:\\n${journalData.journal_text}\\n\\nOdpowiedz TYLKO JSON (bez markdown):\\n{\\n  \\\"weekly_condensation\\\": \\\"...\\\",\\n  \\\"weekly_plan\\\": \\\"...\\\"\\n}`;\n\nreturn [{ json: { user_id: journalData.user_id, week_start: journalData.week_start, full_prompt: fullPrompt } }];"
      }
    },
    {
      "id": "tj-wp-010",
      "name": "Claude Weekly",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [2600, 300],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.full_prompt }}"
      }
