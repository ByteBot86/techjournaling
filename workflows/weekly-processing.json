    {
      "id": "tj-wp-021",
      "name": "Build Tasks Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3080, 520],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data = $('Parse Weekly').first().json;\nconst taskData = $('Collect Task Status').first().json;\nconst maxNew = taskData.max_new_tasks ?? 4;\nconst incompleteList = (taskData.incomplete_tasks || []).join(', ') || 'brak';\n\nconst prompt = `Na podstawie kondensacji tygodnia i planu na przyszły tydzień wygeneruj listę NOWYCH zadań do wykonania.\\n\\nKONDENSACJA TYGODNIA:\\n${data.weekly_condensation}\\n\\nPLAN NA PRZYSZŁY TYDZIEŃ:\\n${data.weekly_plan}\\n\\nNIEWYKONANE ZADANIA Z POPRZEDNIEGO TYGODNIA (już istnieją w Google Tasks, NIE twórz ich ponownie):\\n${incompleteList}\\n\\nWygeneruj dokładnie ${maxNew} NOWYCH, konkretnych zadań (innych niż niewykonane powyżej). Jeśli ${maxNew} = 0, zwróć pustą tablicę [].\\n\\nOdpowiedz TYLKO JSON (bez markdown, bez komentarzy):\\n[\\n  {\"title\": \"...\", \"notes\": \"...\"},\\n  {\"title\": \"...\", \"notes\": \"\"}\\n]`;\n\nreturn [{ json: { user_id: data.user_id, full_prompt: prompt } }];"
      }
    },
    {
      "id": "tj-wp-022",
      "name": "Claude Tasks",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [3320, 520],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.full_prompt }}"
      }
    },
    {
      "id": "tj-wp-023",
      "name": "Anthropic Chat Model 2",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [3320, 700],
      "parameters": {
        "model": { "mode": "id", "value": "claude-sonnet-4-6" }
      },
      "credentials": {
        "anthropicApi": { "id": "rChZltTr5OEPo5JD", "name": "Anthropic account" }
      }
    },
    {
      "id": "tj-wp-024",
      "name": "Parse Tasks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3560, 520],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const userId = $('Build Tasks Prompt').first().json.user_id;\nconst response = $input.first().json.text || $input.first().json.output || '';\nconst cleaned = response.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nlet tasks = [];\ntry {\n  tasks = JSON.parse(cleaned);\n} catch(e) {\n  const match = cleaned.match(/\\[[\\s\\S]*\\]/);\n  tasks = match ? JSON.parse(match[0]) : [];\n}\nif (!Array.isArray(tasks)) tasks = [];\ntasks = tasks.slice(0, 5);\nreturn tasks.map(t => ({ json: { user_id: userId, title: t.title || '', notes: t.notes || '' } }));"
      }
    },
    {
      "id": "tj-wp-025",
