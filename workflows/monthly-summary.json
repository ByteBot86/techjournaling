        "operation": "sendMessage",
        "chatId": "={{ $('Extract Monthly Response').first().json.telegram_id }}",
        "text": "={{ $('Extract Monthly Response').first().json.message }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "credentials": {
