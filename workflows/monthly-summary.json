      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.3,
      "position": [3320, 300],
      "parameters": {
        "source": "database",
        "workflowId": "rUuhiK2xClpGJJad",
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
            "user_id": "={{ $('Extract Monthly Response').first().json.user_id }}",
