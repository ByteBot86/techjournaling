      "typeVersion": 1,
      "position": [3800, 300],
      "parameters": {
        "resource": "row",
        "operation": "update",
        "tableId": "users",
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $('Set User').first().json.user_id }}"
            }
          ]
        },
        "dataToSend": "defineBelow",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "pending_monthly_context",
              "fieldValue": "={{ JSON.stringify({ month: $('Extract Monthly Response').first().json.month, expires_at: new Date(new Date().setHours(23, 59, 59, 999)).toISOString() }) }}"
            }
          ]
        }
      },
      "credentials": {
        "supabaseApi": { "id": "", "name": "Supabase Tech Diary" }
      }
    },
    {
      "id": "tj-ms-020",
