    {
      "id": "tj-ob-005",
      "name": "Check State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const userItem = $('Get User').first().json;\nconst profileItems = $input.all();\nconst hasProfile = profileItems.length > 0 && profileItems[0].json.id != null;\nconst workflowInput = $('Workflow Input').first().json;\n\nreturn [{\n  json: {\n    user_id: userItem.id,\n    telegram_id: userItem.telegram_id,\n    chat_id: workflowInput.chat_id || workflowInput.telegram_id,\n    has_profile: hasProfile\n  }\n}];"
      }
    },
    {
      "id": "tj-ob-006",
