    {
      "id": "tj-ob-012",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2360, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const buildCtx = $('Build Context').first().json;\nconst llmResponse = $input.first().json.text || $input.first().json.output || '';\n\nconst cleaned = llmResponse\n  .replace(/```json\\n?/g, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  const match = cleaned.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : {\n    message: 'Przepraszam, wystąpił błąd. Napisz cokolwiek żeby spróbować ponownie.',\n    next_state: buildCtx.state,\n    update: {}\n  };\n}\n\nconst nextState = parsed.next_state || buildCtx.state;\nconst update = parsed.update || {};\nconst message = parsed.message || 'Coś poszło nie tak. Spróbuj ponownie.';\n\nconst updatedCollectedData = {\n  ...buildCtx.collected_data,\n  ...update,\n  conversation: [...buildCtx.conversation, { role: 'assistant', content: message }]\n};\n\nconst isComplete = nextState === 'complete';\n\nconst amphitheaterText = isComplete\n  ? `Wartości: ${updatedCollectedData.values_summary || ''}. Cel SMART: ${updatedCollectedData.goal_smart || ''}`\n  : '';\n\nreturn [{\n  json: {\n    user_id: buildCtx.user_id,\n    chat_id: buildCtx.chat_id,\n    next_state: nextState,\n    message,\n    collected_data: updatedCollectedData,\n    is_complete: isComplete,\n    amphitheater_text: amphitheaterText,\n    gender: updatedCollectedData.gender || '',\n    values_raw: updatedCollectedData.values_summary || ''\n  }\n}];"
      }
    },
