      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1400, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            {
              "id": "check-has-profile",
              "leftValue": "={{ $json.has_profile }}",
              "rightValue": true,
