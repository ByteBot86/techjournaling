    {
      "id": "tj-ob-009",
      "name": "Build Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1880, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const stateCtx = $('Check State').first().json;\nconst sessionItems = $input.all();\nconst hasSession = sessionItems.length > 0 && sessionItems[0].json.user_id != null;\nconst session = hasSession ? sessionItems[0].json : null;\nconst state = session ? session.state : 'new';\nconst collectedData = (session && session.collected_data) ? session.collected_data : {};\nconst conversation = collectedData.conversation || [];\nconst userMessage = $('Workflow Input').first().json.message_text || '';\n\nconst updatedConversation = [...conversation, { role: 'user', content: userMessage }];\n\nconst stateGuides = {\n  new: 'Rozpocznij onboarding. Przywitaj ciepło i krótko (max 2 zdania). Zapytaj o najważniejsze wartości życiowe i zawodowe użytkownika. Ustaw next_state: \"values\".',\n  values: `Zbierasz wartości użytkownika. Oceń czy masz wystarczające informacje — minimum 2 odpowiedzi w historii rozmowy, treść konkretna. Jeśli tak: podsumuj wartości w update.values_summary (2-4 zdania) i poproś o potwierdzenie. Ustaw next_state: \"values_confirm\". Jeśli nie: zadaj JEDNO pogłębiające pytanie. Ustaw next_state: \"values\".`,\n  values_confirm: `Użytkownik odpowiada na pytanie o potwierdzenie wartości. Podsumowanie: \"${collectedData.values_summary || ''}\". TAK/tak/yes/zgadza się → przejdź do pytania o płeć (mężczyzna/kobieta/inne), next_state: \"gender\". NIE/nie → wróć do zbierania, next_state: \"values\".`,\n  gender: `Zbierz płeć użytkownika (mężczyzna/kobieta/inne). Zapisz w update.gender. Następnie zapytaj: \"Co jest Twoim najważniejszym celem zawodowym na najbliższy rok?\", next_state: \"goal\".`,\n  goal: `Zbierasz cel zawodowy. Min 1-2 odpowiedzi wystarczy. Jeśli masz wystarczające informacje: sformułuj cel SMART w update.goal_smart, poproś o potwierdzenie, next_state: \"goal_confirm\". Jeśli nie: jedno pogłębiające pytanie, next_state: \"goal\".`,\n  goal_confirm: `Użytkownik potwierdza cel SMART: \"${collectedData.goal_smart || ''}\". TAK/tak/yes → zakończ onboarding! Wyślij ciepłą wiadomość końcową (maks 3 zdania), next_state: \"complete\". NIE/nie → zapytaj co zmienić, next_state: \"goal\".`\n};\n\nconst collectedInfo = Object.entries(collectedData)\n  .filter(([k]) => k !== 'conversation')\n  .map(([k, v]) => `${k}: ${v}`)\n  .join('\\n') || '(brak)';\n\nconst historyText = updatedConversation\n  .map(m => `${m.role === 'user' ? 'UŻYTKOWNIK' : 'ASYSTENT'}: ${m.content}`)\n  .join('\\n') || '(brak — to pierwsza wiadomość)';\n\nconst fullPrompt = `Prowadzisz onboarding użytkownika aplikacji do journalingu kariery.\\n\\nAKTUALNY STAN: ${state}\\nZEBRANE INFORMACJE:\\n${collectedInfo}\\n\\nINSTRUKCJA DLA TEGO STANU:\\n${stateGuides[state] || stateGuides.new}\\n\\nHISTORIA ROZMOWY:\\n${historyText}\\n\\nOdpowiedz TYLKO JSON (bez markdown, bez komentarzy):\\n{\\n  \"message\": \"wiadomość do wysłania użytkownikowi\",\\n  \"next_state\": \"values|values_confirm|gender|goal|goal_confirm|complete\",\\n  \"update\": {}\\n}`;\n\nreturn [{\n  json: {\n    user_id: stateCtx.user_id,\n    chat_id: stateCtx.chat_id,\n    state,\n    collected_data: collectedData,\n    conversation: updatedConversation,\n    full_prompt: fullPrompt\n  }\n}];"
      }
    },
    {
